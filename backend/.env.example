# ── Database ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pranitra
DB_USER=pranitra
DB_PASSWORD=

# ── Node ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── AWS SES (email) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_SES_FROM=PRANITRA ERP <admin@pranitra.com>

# ── Microsoft Teams (optional) ──────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── Session / Security ──────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ── Zoho People (optional) ──────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ENCRYPT_KEY=

# ── Microsoft Outlook OAuth (optional) ──────────────────────────
MS_CLIENT_ID=
MS_TENANT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=

# ── URLs ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
VITE_API_URL=/api
