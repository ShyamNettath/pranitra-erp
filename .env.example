# ── Database ────────────────────────────────────────────────────
DB_NAME=pranitra
DB_USER=pranitra
DB_PASSWORD=changeme_in_production

# ── Node ────────────────────────────────────────────────────────
NODE_ENV=production

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── AWS SES ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_SES_FROM=PRANITRA ERP <admin@pranitra.com>

# ── Microsoft Teams (optional) ──────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── Session / Security (Admin-configurable via UI too) ──────────
SESSION_TIMEOUT_MINUTES=30
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ── Zoho People (optional — Phase 1 read-only sync) ─────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── URLs ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
VITE_API_URL=/api
